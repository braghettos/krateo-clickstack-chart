# SLO Alert Bootstrap Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# HyperDX base URL (e.g. http://localhost:3000 when port-forwarding)
HYPERDX_URL=http://localhost:3000

# Personal API key from HyperDX (Settings → API Keys)
HYPERDX_API_KEY=

# Webhook ID for alert delivery (portal / alert-proxy / email integration)
WEBHOOK_ID=

# --- SLO targets (defaults shown; override per deployment) -----------------
# API request p95 latency target, milliseconds
SLO_API_LATENCY_P95_MS=500
# UI page-interaction p95 latency target, milliseconds
SLO_UI_LATENCY_P95_MS=2000
# Availability target, percent (used in dashboards / burn-rate math)
SLO_AVAILABILITY_TARGET=99.9
# Max ERROR/FATAL log lines per 5m per namespace before alerting
SLO_ERROR_RATE_MAX=10
# Max failing server spans per 5m per service before alerting
SLO_ERROR_SPAN_MAX=5
